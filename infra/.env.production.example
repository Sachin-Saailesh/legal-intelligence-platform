# ── Azure OpenAI — Chat ────────────────────────────────────────────────────────
AZURE_CHAT_ENDPOINT=https://YOUR_RESOURCE.openai.azure.com/
AZURE_CHAT_API_KEY=your_key_here
AZURE_CHAT_DEPLOYMENT=gpt-5-chat
AZURE_CHAT_API_VERSION=2024-12-01-preview

# ── Azure OpenAI — Embeddings ──────────────────────────────────────────────────
AZURE_EMBEDDING_ENDPOINT=https://YOUR_RESOURCE.openai.azure.com/
AZURE_EMBEDDING_API_KEY=your_key_here
AZURE_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AZURE_EMBEDDING_API_VERSION=2024-02-01

# ── PostgreSQL (Neon) ──────────────────────────────────────────────────────────
# Copy the connection string from Neon dashboard → Connection Details → asyncpg
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.us-east-2.aws.neon.tech/lexmind?sslmode=require
DATABASE_SYNC_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/lexmind?sslmode=require

# ── Qdrant Cloud ───────────────────────────────────────────────────────────────
# Copy URL and API key from Qdrant Cloud dashboard → your cluster
QDRANT_URL=https://xxx.us-east4-0.gcp.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here
QDRANT_COLLECTION=lexmind_documents

# ── Neo4j (disabled in cloud deployment) ──────────────────────────────────────
NEO4J_ENABLED=false
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=lexmind_password

# ── Redis / Celery (disabled in cloud deployment) ─────────────────────────────
REDIS_ENABLED=false
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── Langfuse (optional — leave blank to disable tracing) ──────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Security ───────────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_64_CHAR_HEX

# ── CORS — set to your Vercel frontend URL ─────────────────────────────────────
ALLOWED_ORIGINS=https://your-app.vercel.app

# ── App ────────────────────────────────────────────────────────────────────────
APP_ENV=production
LOG_LEVEL=INFO
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=50
